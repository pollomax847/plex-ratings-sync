# Exemple de configuration pour docker-compose.yml
# Copie ce fichier en .env puis adapte les chemins.
#   cp docker/.env.example .env

# --- Chemins hôte → conteneur -----------------------------------------------
# Dossier 'Plex Media Server' contenant Preferences.xml et Plug-in Support/
# (monté en lecture seule dans le conteneur)
# Voir TUTO.md §3.1 pour les chemins typiques selon ton install Plex
PLEX_CONFIG_HOST=/var/snap/plexmediaserver/common/Library/Application Support/Plex Media Server

# Racine de ta bibliothèque musicale
MUSIC_HOST=/home/paulceline/Musiques

# Dossier de playlists M3U
PLAYLISTS_HOST=/mnt/MyBook/playlists

# Où stocker les logs et queues (persistant)
DATA_HOST=./docker-data

# --- API Plex (optionnel, pour les scripts qui l'utilisent) -----------------
PLEX_URL=http://host.docker.internal:32400
PLEX_TOKEN=
# Style des posters de playlists (JSON dans le conteneur)
PLEX_POSTER_STYLE_CONFIG=/app/playlists/poster_style.default.json
# Presets disponibles:
# /app/playlists/poster_style.neon_retro.json
# /app/playlists/poster_style.minimal_bw.json
# /app/playlists/poster_style.sunset_orange_blue.json

# --- Last.fm (playlists basées sur ton compte) ------------------------------
# Crée une API key sur https://www.last.fm/api/account/create
LASTFM_USER=
LASTFM_API_KEY=
# Période possible: overall, 7day, 1month, 3month, 6month, 12month
LASTFM_PERIOD=overall
# Pages de 1000 titres max à récupérer
LASTFM_MAX_PAGES=5

# --- Outils SongRec (montés depuis l'hôte dans webui) ----------------------
# Vérifier ce chemin avec: command -v songrec
SONGREC_BIN_HOST=/usr/bin/songrec

# --- UI web -----------------------------------------------------------------
# Port exposé sur l'hôte (UI accessible sur http://localhost:<PORT>)
WEBUI_PORT=8765
# Bind local par défaut (évite d'exposer l'UI sur le LAN)
WEBUI_BIND=127.0.0.1
# Si renseigné, exige ?token=XXX ou header X-Token sur chaque requête
WEBUI_TOKEN=
# Redirection HTTP->HTTPS seulement si reverse proxy TLS en amont
WEBUI_ENFORCE_HTTPS=0
# Cookies secure (à garder à 1 en prod)
WEBUI_COOKIE_SECURE=1
# Contrôle Docker depuis l'UI (très sensible) : 0 par défaut
WEBUI_ALLOW_DOCKER_CONTROL=0

# --- Proxy TLS local (service webui_tls) ------------------------------------
# URL finale : https://localhost:<WEBUI_TLS_PORT>
WEBUI_TLS_BIND=127.0.0.1
WEBUI_TLS_PORT=9443
