# Exemple de configuration pour docker-compose.yml
# Copie ce fichier en .env puis adapte les chemins.
#   cp docker/.env.example .env

# --- Chemins hôte → conteneur -----------------------------------------------
# Dossier contenant com.plexapp.plugins.library.db (monté en lecture seule)
# Voir TUTO.md §3.1 pour les chemins typiques selon ton install Plex
PLEX_CONFIG_HOST=/var/snap/plexmediaserver/common/Library/Application Support/Plex Media Server

# Racine de ta bibliothèque musicale
MUSIC_HOST=/home/paulceline/Musiques

# Dossier de playlists M3U
PLAYLISTS_HOST=/mnt/MyBook/playlists

# Dossier contenant "iTunes Music Library.xml"
ITUNES_HOST=/mnt/MyBook/itunes

# Où stocker les logs et queues (persistant)
DATA_HOST=./docker-data

# --- API Plex (optionnel, pour les scripts qui l'utilisent) -----------------
PLEX_URL=http://host.docker.internal:32400
PLEX_TOKEN=WQQySxr3SBPY-Sn77Yuk

# --- Last.fm (playlists basées sur ton compte) ------------------------------
# 📖 GUIDE COMPLET: voir LASTFM_SETUP.md ou http://localhost:8900/playlists (onglet Auto ✨)
#
# Étapes:
#   1. Allez sur https://www.last.fm/api/account/create
#   2. Créez une application (Application name: "PlexAmp Auto Playlists")
#   3. Copiez l'API Key (longue chaîne hexadécimale)
#   4. Remplissez ci-dessous:
#
# Votre pseudo Last.fm (ex: pol2_1, alice_music)
# Trouvez-le: https://www.last.fm/user/YOUR_PSEUDO
LASTFM_USER=pol2_1

# Votre API Key (créée à https://www.last.fm/api/account/create)
# ⚠️ Gardez-la secrète ! Ne la partager pas.
# Laissez vide si vous préférez la saisir via l'interface webui
LASTFM_API_KEY=4cecf26d70998e5bb4238e37a1408db7

# Période d'écoutes à récupérer:
#   overall     = toutes vos écoutes (depuis toujours)
#   7day        = 7 derniers jours
#   1month      = 1 dernier mois
#   3month      = 3 derniers mois
#   6month      = 6 derniers mois
#   12month     = 12 derniers mois
LASTFM_PERIOD=overall

# Nombre de pages Last.fm à récupérer (1000 titres par page)
# Max 50, mais 5 c'est généralement suffisant (= 5000 titres)
LASTFM_MAX_PAGES=5

# --- UI web -----------------------------------------------------------------
# Port exposé sur l'hôte (UI accessible sur http://localhost:<PORT>)
WEBUI_PORT=8900
# Si renseigné, exige ?token=XXX ou header X-Token sur chaque requête
WEBUI_TOKEN=

# --- slskd (Soulseek) -------------------------------------------------------
# URL publique de l'API slskd (port mappé sur l'hôte → http://host.docker.internal depuis Docker)
SLSKD_URL=http://host.docker.internal:5032
# Clé API slskd (slskd → Settings → Security → API Keys)
SLSKD_API_KEY=0354474c6d638b819b81cefce65c256c11761375913aca4f6614c8681e35318fe761eb8d30ed375291f547b66853dd24
WEBUI_ALLOW_DOCKER_CONTROL=1
