{
  "size": 600,
  "overlay_alpha": 115,
  "title_size": 46,
  "subtitle_size": 23,
  "emoji_size": 84,
  "title_start_y": 292,
  "title_line_step": 52,
  "text_padding": 56,

  "title_color": [255, 240, 255, 255],
  "title_shadow_color": [80, 0, 60, 215],
  "subtitle_color": [255, 200, 240, 210],
  "line_color": [255, 100, 200, 110],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🌸",
  "default_colors": [[180, 0, 120], [255, 80, 180]],

  "themes": [
