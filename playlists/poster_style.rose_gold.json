      "emoji": "💗",
      "colors": [[160, 0, 100], [255, 60, 160]]
    },
    {
      "keywords": ["pop", "dance", "hits"],
      "match": "any",
      "emoji": "🎀",
      "colors": [[190, 20, 130], [255, 100, 200]]
    },
    {
      "keywords": ["love", "amour", "romance", "romantic"],
      "match": "any",
      "emoji": "❤",
      "colors": [[160, 0, 80], [250, 50, 150]]
    },
    {
      "keywords": ["disco", "funk", "groove", "party"],
      "match": "any",
      "emoji": "💃",
      "colors": [[200, 30, 150], [255, 120, 210]]
    },
    {
      "keywords": ["kpop", "k-pop", "jpop", "j-pop", "asian"],
      "match": "any",
      "emoji": "🌸",
