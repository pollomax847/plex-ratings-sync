{
  "size": 600,
  "overlay_alpha": 110,
  "title_size": 44,
  "subtitle_size": 24,
  "emoji_size": 80,
  "title_start_y": 300,
  "title_line_step": 50,
  "text_padding": 60,

  "title_color": [255, 255, 255, 255],
  "title_shadow_color": [0, 0, 0, 180],
  "subtitle_color": [210, 210, 210, 220],
  "line_color": [255, 255, 255, 90],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🎵",
  "default_colors": [[40, 85, 130], [15, 165, 145]],

  "themes": [
    {
      "keywords": ["stars 80"],
      "match": "all",
      "emoji": "⭐",
      "colors": [[121, 40, 202], [255, 0, 128]]
    },
    {
      "keywords": ["running", "workout"],
      "match": "any",
      "emoji": "🏃",
      "colors": [[255, 94, 0], [255, 195, 0]]
    },
    {
      "keywords": ["chill", "concentration", "relax"],
      "match": "any",
      "emoji": "🧘",
      "colors": [[0, 96, 140], [0, 168, 150]]
    }
  ]
}
