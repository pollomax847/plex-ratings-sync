{
  "size": 600,
  "overlay_alpha": 100,
  "title_size": 50,
  "subtitle_size": 23,
  "emoji_size": 88,
  "title_start_y": 285,
  "title_line_step": 56,
  "text_padding": 48,

  "title_color": [255, 230, 100, 255],
  "title_shadow_color": [120, 0, 0, 240],
  "title_stroke_width": 0,
  "title_stroke_color": [0, 0, 0, 0],

  "subtitle_color": [255, 180, 80, 220],
  "line_color": [255, 100, 0, 160],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🔥",
  "default_colors": [[15, 0, 0], [180, 30, 0]],

  "themes": [
    {
      "keywords": ["metal", "heavy", "doom", "death", "black metal"],
      "match": "any",
      "emoji": "💀",
      "colors": [[10, 0, 0], [150, 20, 0]]
    },
    {
      "keywords": ["rock", "hard", "punk", "stoner"],
      "match": "any",
      "emoji": "🤘",
      "colors": [[20, 0, 0], [200, 40, 0]]
    },
    {
      "keywords": ["industrial", "dark", "noise"],
      "match": "any",
      "emoji": "⚙",
      "colors": [[8, 0, 0], [130, 15, 0]]
    },
    {
      "keywords": ["workout", "running", "rage", "intense"],
      "match": "any",
      "emoji": "🔥",
      "colors": [[15, 0, 0], [220, 60, 0]]
    },
    {
      "keywords": ["dnb", "drum", "drum and bass", "dubstep"],
      "match": "any",
      "emoji": "⚡",
      "colors": [[12, 0, 0], [180, 30, 5]]
    }
  ]
}
