{
  "size": 600,
  "overlay_alpha": 100,
  "title_size": 48,
  "subtitle_size": 23,
  "emoji_size": 86,
  "title_start_y": 285,
  "title_line_step": 54,
  "text_padding": 52,

  "title_color": [255, 255, 255, 255],
  "title_shadow_color": [100, 0, 180, 200],
  "title_stroke_width": 0,
  "title_stroke_color": [0, 0, 0, 0],

  "subtitle_color": [200, 170, 255, 215],
  "line_color": [150, 80, 255, 120],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "✨",
  "default_colors": [[0, 0, 20], [30, 0, 80]],

  "themes": [
    {
      "keywords": ["ambient", "space", "cosmos", "space"],
      "match": "any",
      "emoji": "🌌",
      "colors": [[0, 0, 15], [25, 0, 70]]
    },
    {
      "keywords": ["dream", "reve", "sleep", "night", "nuit"],
      "match": "any",
      "emoji": "🌙",
      "colors": [[0, 0, 20], [30, 0, 80]]
    },
    {
      "keywords": ["electronic", "techno", "trance", "edm", "psytrance"],
      "match": "any",
      "emoji": "⚡",
      "colors": [[0, 0, 25], [40, 0, 100]]
    },
    {
      "keywords": ["chill", "relax", "float", "lofi", "lo-fi"],
      "match": "any",
      "emoji": "💫",
      "colors": [[0, 0, 18], [28, 0, 75]]
    },
    {
      "keywords": ["metal", "heavy", "dark", "doom"],
      "match": "any",
      "emoji": "💀",
      "colors": [[0, 0, 10], [15, 0, 50]]
    }
  ]
}
