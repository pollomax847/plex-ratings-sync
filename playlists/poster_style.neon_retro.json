{
  "size": 600,
  "overlay_alpha": 95,
  "title_size": 46,
  "subtitle_size": 24,
  "emoji_size": 86,
  "title_start_y": 300,
  "title_line_step": 52,
  "text_padding": 58,

  "title_color": [245, 255, 255, 255],
  "title_shadow_color": [20, 0, 35, 220],
  "subtitle_color": [220, 245, 255, 220],
  "line_color": [210, 255, 255, 110],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🎛️",
  "default_colors": [[30, 0, 75], [0, 170, 200]],

  "themes": [
    {
      "keywords": ["electronic", "club", "dance"],
      "match": "any",
      "emoji": "🎛️",
      "colors": [[65, 0, 120], [0, 210, 255]]
    },
    {
      "keywords": ["stars 80", "generation top 50"],
      "match": "any",
      "emoji": "✨",
      "colors": [[140, 0, 255], [255, 0, 160]]
    },
    {
      "keywords": ["running", "workout"],
      "match": "any",
      "emoji": "⚡",
      "colors": [[255, 50, 0], [255, 220, 0]]
    }
  ]
}
