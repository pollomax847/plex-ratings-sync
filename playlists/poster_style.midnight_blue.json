{
  "size": 600,
  "overlay_alpha": 140,
  "title_size": 44,
  "subtitle_size": 22,
  "emoji_size": 76,
  "title_start_y": 305,
  "title_line_step": 50,
  "text_padding": 65,

  "title_color": [255, 255, 255, 255],
  "title_shadow_color": [0, 0, 0, 200],
  "subtitle_color": [200, 220, 255, 200],
  "line_color": [100, 180, 255, 100],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🌊",
  "default_colors": [[0, 30, 80], [0, 100, 160]],

  "themes": [
    {
      "keywords": ["jazz", "blues", "swing", "soul"],
      "match": "any",
      "emoji": "🎷",
      "colors": [[0, 20, 70], [0, 80, 140]]
    },
    {
      "keywords": ["chill", "relax", "zen", "lounge", "ambient"],
      "match": "any",
      "emoji": "🌊",
      "colors": [[0, 40, 90], [0, 130, 180]]
    },
    {
      "keywords": ["concentration", "travail", "focus", "study"],
      "match": "any",
      "emoji": "🎯",
      "colors": [[10, 30, 80], [20, 100, 160]]
    },
    {
      "keywords": ["classical", "classique", "piano", "orchestra"],
      "match": "any",
      "emoji": "🎹",
      "colors": [[0, 20, 60], [0, 70, 120]]
    },
    {
      "keywords": ["indie", "folk", "acoustic"],
      "match": "any",
      "emoji": "🎸",
      "colors": [[10, 50, 100], [30, 120, 170]]
    },
    {
      "keywords": ["night", "nuit", "late", "minuit"],
      "match": "any",
      "emoji": "🌙",
      "colors": [[5, 10, 50], [0, 60, 110]]
    }
  ]
}
