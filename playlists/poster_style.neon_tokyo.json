{
  "size": 600,
  "overlay_alpha": 105,
  "title_size": 49,
  "subtitle_size": 23,
  "emoji_size": 86,
  "title_start_y": 288,
  "title_line_step": 55,
  "text_padding": 48,

  "title_color": [255, 30, 130, 255],
  "title_shadow_color": [0, 220, 255, 180],
  "title_stroke_width": 0,
  "title_stroke_color": [0, 0, 0, 0],

  "subtitle_color": [0, 230, 255, 220],
  "line_color": [255, 20, 120, 140],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🌃",
  "default_colors": [[5, 0, 15], [20, 0, 45]],

  "themes": [
