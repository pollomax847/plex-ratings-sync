      "colors": [[5, 0, 20], [18, 0, 50]]
    },
    {
      "keywords": ["kpop", "k-pop", "jpop", "j-pop", "japan", "tokyo", "asian"],
      "match": "any",
      "emoji": "🌸",
      "colors": [[8, 0, 20], [22, 0, 55]]
    },
    {
      "keywords": ["rap", "hip-hop", "trap", "urban"],
      "match": "any",
      "emoji": "🎤",
      "colors": [[5, 0, 15], [18, 0, 42]]
    },
    {
      "keywords": ["gaming", "game", "cyberpunk", "cyber"],
      "match": "any",
      "emoji": "🎮",
      "colors": [[3, 0, 12], [15, 0, 38]]
    },
    {
      "keywords": ["pop", "dance", "hits", "charts"],
      "match": "any",
