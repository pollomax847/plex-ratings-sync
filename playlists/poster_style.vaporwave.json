{
  "size": 600,
  "overlay_alpha": 60,
  "title_size": 54,
  "subtitle_size": 22,
  "emoji_size": 82,
  "title_start_y": 270,
  "title_line_step": 62,
  "text_padding": 48,

  "title_color": [255, 210, 250, 255],
  "title_shadow_color": [180, 0, 180, 180],
  "title_stroke_width": 0,
  "title_stroke_color": [0, 0, 0, 0],

  "subtitle_color": [150, 255, 255, 220],
  "line_color": [255, 100, 220, 130],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🌴",
  "default_colors": [[60, 0, 100], [180, 20, 160]],

  "themes": [
    {
      "keywords": ["80", "80s", "années 80", "annees 80", "synthwave", "retrowave"],
      "match": "any",
      "emoji": "🌆",
      "colors": [[80, 0, 120], [200, 30, 180]]
    },
    {
      "keywords": ["dream", "reve", "ambient", "chill", "lofi", "lo-fi"],
      "match": "any",
      "emoji": "💭",
      "colors": [[50, 0, 90], [160, 20, 150]]
    },
    {
      "keywords": ["pop", "indie", "alternative"],
      "match": "any",
      "emoji": "🌸",
      "colors": [[70, 10, 110], [190, 40, 170]]
    },
    {
      "keywords": ["electronic", "synth", "electro"],
      "match": "any",
      "emoji": "🎛",
      "colors": [[40, 0, 80], [150, 10, 140]]
    },
    {
      "keywords": ["japan", "tokyo", "asian", "kpop", "k-pop"],
      "match": "any",
      "emoji": "🌸",
      "colors": [[90, 0, 130], [210, 50, 190]]
    }
  ]
}
