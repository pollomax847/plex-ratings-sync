{
  "size": 600,
  "overlay_alpha": 35,
  "title_size": 72,
  "subtitle_size": 24,
  "emoji_size": 0,
  "title_start_y": 250,
  "title_line_step": 80,
  "text_padding": 40,

  "title_color": [232, 220, 190, 255],
  "title_shadow_color": [0, 0, 0, 255],
  "title_stroke_width": 10,
  "title_stroke_color": [0, 0, 0, 255],

  "subtitle_color": [200, 185, 155, 210],
  "line_color": [0, 0, 0, 0],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "",
  "default_colors": [[90, 80, 65], [140, 125, 100]],

  "themes": [
    {
      "keywords": ["rap", "hip-hop", "hip hop", "trap", "urban"],
      "match": "any",
      "emoji": "",
      "colors": [[80, 70, 55], [130, 115, 90]]
    },
    {
      "keywords": ["90", "90s", "années 90", "annees 90", "old school"],
      "match": "any",
      "emoji": "",
      "colors": [[85, 75, 60], [135, 120, 95]]
    },
    {
      "keywords": ["street", "underground", "boom bap", "funk", "groove"],
      "match": "any",
      "emoji": "",
      "colors": [[75, 65, 50], [125, 110, 85]]
    }
  ]
}
