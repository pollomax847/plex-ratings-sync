{
  "size": 600,
  "overlay_alpha": 90,
  "title_size": 48,
  "subtitle_size": 24,
  "emoji_size": 88,
  "title_start_y": 290,
  "title_line_step": 54,
  "text_padding": 50,

  "title_color": [255, 255, 255, 255],
  "title_shadow_color": [180, 80, 0, 210],
  "subtitle_color": [255, 230, 180, 220],
  "line_color": [255, 180, 50, 130],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🔥",
  "default_colors": [[200, 50, 0], [255, 200, 0]],

  "themes": [
    {
      "keywords": ["running", "workout", "sport", "gym", "energie", "energy"],
      "match": "any",
      "emoji": "⚡",
      "colors": [[220, 40, 0], [255, 210, 0]]
    },
    {
      "keywords": ["rock", "metal", "hard"],
      "match": "any",
      "emoji": "🎸",
      "colors": [[180, 0, 0], [255, 100, 0]]
    },
    {
      "keywords": ["latin", "salsa", "reggaeton", "fiesta"],
      "match": "any",
      "emoji": "💃",
      "colors": [[210, 80, 0], [255, 215, 0]]
    },
    {
      "keywords": ["funk", "groove", "disco"],
      "match": "any",
      "emoji": "🕺",
      "colors": [[200, 60, 10], [255, 200, 30]]
    },
    {
      "keywords": ["hip-hop", "rap", "trap"],
      "match": "any",
      "emoji": "🎤",
      "colors": [[150, 30, 0], [255, 120, 0]]
    }
  ]
}
