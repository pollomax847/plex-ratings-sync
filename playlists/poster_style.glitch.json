{
  "size": 600,
  "overlay_alpha": 130,
  "title_size": 50,
  "subtitle_size": 22,
  "emoji_size": 84,
  "title_start_y": 285,
  "title_line_step": 56,
  "text_padding": 48,

  "title_color": [0, 255, 240, 255],
  "title_shadow_color": [255, 0, 130, 200],
  "title_stroke_width": 0,
  "title_stroke_color": [0, 0, 0, 0],

  "subtitle_color": [255, 100, 200, 220],
  "line_color": [0, 240, 230, 150],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "📺",
  "default_colors": [[0, 0, 0], [25, 25, 35]],

  "themes": [
    {
      "keywords": ["electronic", "glitch", "experimental", "idm"],
      "match": "any",
      "emoji": "📡",
      "colors": [[0, 0, 0], [20, 20, 30]]
    },
    {
      "keywords": ["techno", "house", "club", "rave"],
      "match": "any",
      "emoji": "🎛",
      "colors": [[0, 0, 0], [25, 25, 35]]
    },
    {
      "keywords": ["cyber", "future", "matrix", "hack"],
      "match": "any",
      "emoji": "💾",
      "colors": [[0, 0, 0], [15, 20, 30]]
    },
    {
      "keywords": ["punk", "underground", "noise", "industrial"],
      "match": "any",
      "emoji": "📺",
      "colors": [[0, 0, 0], [22, 22, 28]]
    },
    {
      "keywords": ["gaming", "game", "arcade"],
      "match": "any",
      "emoji": "🎮",
      "colors": [[0, 0, 0], [20, 20, 30]]
    }
  ]
}
