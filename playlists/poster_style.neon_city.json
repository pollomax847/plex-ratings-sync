{
  "size": 600,
  "overlay_alpha": 160,
  "title_size": 47,
  "subtitle_size": 23,
  "emoji_size": 86,
  "title_start_y": 290,
  "title_line_step": 53,
  "text_padding": 52,

  "title_color": [0, 255, 220, 255],
  "title_shadow_color": [0, 180, 160, 180],
  "subtitle_color": [255, 50, 180, 220],
  "line_color": [0, 255, 200, 160],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🌆",
  "default_colors": [[5, 0, 25], [15, 0, 50]],

  "themes": [
    {
      "keywords": ["80", "80s", "années 80", "annees 80", "eighties"],
      "match": "any",
      "emoji": "📼",
      "colors": [[5, 0, 30], [20, 0, 60]]
    },
    {
      "keywords": ["synth", "synthwave", "retrowave", "outrun"],
      "match": "any",
      "emoji": "🌇",
      "colors": [[10, 0, 35], [25, 0, 70]]
    },
    {
      "keywords": ["electronic", "electro", "techno", "club"],
      "match": "any",
      "emoji": "🎛",
      "colors": [[0, 0, 30], [10, 0, 55]]
    },
    {
      "keywords": ["night", "nuit", "dark", "midnight", "minuit"],
      "match": "any",
      "emoji": "🌃",
      "colors": [[0, 0, 20], [8, 0, 45]]
    },
    {
      "keywords": ["cyberpunk", "cyber", "future", "futur"],
      "match": "any",
      "emoji": "🤖",
      "colors": [[5, 0, 40], [20, 0, 80]]
    },
    {
      "keywords": ["rock", "pop", "hits", "stars"],
      "match": "any",
      "emoji": "⭐",
      "colors": [[8, 0, 30], [22, 0, 65]]
    }
  ]
}
