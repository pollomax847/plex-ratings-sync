{
  "size": 600,
  "overlay_alpha": 40,
  "title_size": 50,
  "subtitle_size": 22,
  "emoji_size": 84,
  "title_start_y": 285,
  "title_line_step": 56,
  "text_padding": 50,

  "title_color": [80, 50, 110, 255],
  "title_shadow_color": [255, 200, 230, 220],
  "title_stroke_width": 0,
  "title_stroke_color": [0, 0, 0, 0],

  "subtitle_color": [120, 90, 150, 220],
  "line_color": [200, 170, 220, 180],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "🌷",
  "default_colors": [[255, 220, 240], [200, 230, 255]],

  "themes": [
    {
      "keywords": ["love", "amour", "romance", "tendre"],
      "match": "any",
      "emoji": "💗",
      "colors": [[255, 215, 230], [255, 230, 245]]
    },
    {
      "keywords": ["chill", "soft", "calm", "calme", "relax"],
      "match": "any",
      "emoji": "🌸",
      "colors": [[255, 225, 235], [220, 240, 255]]
    },
    {
      "keywords": ["dream", "reve", "indie", "bedroom"],
      "match": "any",
      "emoji": "💭",
      "colors": [[235, 220, 255], [220, 235, 255]]
    },
    {
      "keywords": ["spring", "printemps", "morning", "matin"],
      "match": "any",
      "emoji": "🌷",
      "colors": [[255, 230, 220], [220, 245, 230]]
    },
    {
      "keywords": ["acoustic", "folk", "indie pop"],
      "match": "any",
      "emoji": "🎀",
      "colors": [[250, 230, 240], [225, 240, 250]]
    },
    {
      "keywords": ["kids", "enfants", "children", "happy", "joie"],
      "match": "any",
      "emoji": "🎈",
      "colors": [[255, 235, 220], [220, 245, 235]]
    }
  ]
}
