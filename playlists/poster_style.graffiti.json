{
  "size": 600,
  "overlay_alpha": 85,
  "title_size": 50,
  "subtitle_size": 24,
  "emoji_size": 90,
  "title_start_y": 285,
  "title_line_step": 56,
  "text_padding": 45,

  "title_color": [255, 240, 60, 255],
  "title_shadow_color": [0, 0, 0, 255],
  "subtitle_color": [255, 200, 50, 210],
  "line_color": [255, 200, 0, 150],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "✍",
  "default_colors": [[20, 10, 5], [60, 30, 10]],

  "themes": [
    {
      "keywords": ["rap", "hip-hop", "hip hop", "trap", "urban"],
      "match": "any",
      "emoji": "🎤",
      "colors": [[15, 5, 0], [50, 20, 5]]
    },
    {
      "keywords": ["90", "90s", "années 90", "annees 90"],
      "match": "any",
      "emoji": "💿",
      "colors": [[20, 8, 0], [65, 25, 8]]
    },
    {
      "keywords": ["old school", "old-school", "boom bap", "classic"],
      "match": "any",
      "emoji": "📻",
      "colors": [[10, 5, 0], [45, 18, 5]]
    },
    {
      "keywords": ["funk", "soul", "groove"],
      "match": "any",
      "emoji": "🕺",
      "colors": [[25, 10, 0], [70, 30, 10]]
    },
    {
      "keywords": ["street", "underground", "rebel"],
      "match": "any",
      "emoji": "✊",
      "colors": [[10, 0, 0], [40, 15, 5]]
    }
  ]
}
