{
  "size": 600,
  "overlay_alpha": 120,
  "title_size": 46,
  "subtitle_size": 23,
  "emoji_size": 84,
  "title_start_y": 295,
  "title_line_step": 52,
  "text_padding": 55,

  "title_color": [245, 220, 255, 255],
  "title_shadow_color": [20, 0, 40, 220],
  "subtitle_color": [200, 170, 240, 210],
  "line_color": [190, 130, 255, 100],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/ancient-scripts/Symbola_hint.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "✨",
  "default_colors": [[30, 0, 80], [100, 0, 180]],

  "themes": [
    {
      "keywords": ["rap", "hip-hop", "hip hop", "urban"],
      "match": "any",
      "emoji": "🎤",
      "colors": [[20, 0, 60], [120, 0, 200]]
    },
    {
      "keywords": ["r&b", "rnb", "soul"],
      "match": "any",
      "emoji": "💜",
      "colors": [[60, 0, 100], [180, 50, 220]]
    },
    {
      "keywords": ["electronic", "techno", "house", "club", "edm"],
      "match": "any",
      "emoji": "🎛",
      "colors": [[0, 0, 80], [80, 0, 200]]
    },
    {
      "keywords": ["night", "nuit", "minuit", "midnight"],
      "match": "any",
      "emoji": "🌃",
      "colors": [[10, 0, 50], [70, 20, 130]]
    },
    {
      "keywords": ["dream", "reve", "ambient"],
      "match": "any",
      "emoji": "💫",
      "colors": [[40, 10, 90], [140, 60, 200]]
    }
  ]
}
