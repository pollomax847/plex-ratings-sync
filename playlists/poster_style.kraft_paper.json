{
  "size": 600,
  "overlay_alpha": 25,
  "title_size": 56,
  "subtitle_size": 22,
  "emoji_size": 0,
  "title_start_y": 260,
  "title_line_step": 64,
  "text_padding": 42,

  "title_color": [40, 30, 22, 255],
  "title_shadow_color": [200, 180, 150, 100],
  "title_stroke_width": 0,
  "title_stroke_color": [0, 0, 0, 0],

  "subtitle_color": [90, 75, 55, 220],
  "line_color": [80, 65, 45, 200],

  "font_path": "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf",
  "emoji_font_path": "/usr/share/fonts/truetype/noto/NotoSansSymbols2-Regular.ttf",

  "strip_auto_prefix": true,
  "strip_count_suffix": true,

  "default_emoji": "",
  "default_colors": [[245, 235, 215], [230, 215, 185]],

  "themes": [
    {
      "keywords": ["folk", "acoustic", "indie", "americana"],
      "match": "any",
      "emoji": "",
      "colors": [[245, 235, 215], [225, 210, 180]]
    },
    {
      "keywords": ["jazz", "bossa", "swing"],
      "match": "any",
      "emoji": "",
      "colors": [[248, 238, 218], [228, 213, 183]]
    },
    {
      "keywords": ["classical", "classique", "piano", "chamber"],
      "match": "any",
      "emoji": "",
      "colors": [[250, 240, 220], [230, 215, 185]]
    },
    {
      "keywords": ["minimal", "minimalist", "ambient", "modern"],
      "match": "any",
      "emoji": "",
      "colors": [[252, 245, 230], [235, 220, 195]]
    },
    {
      "keywords": ["vintage", "retro", "old", "classic"],
      "match": "any",
      "emoji": "",
      "colors": [[242, 230, 205], [222, 205, 170]]
    }
  ]
}
