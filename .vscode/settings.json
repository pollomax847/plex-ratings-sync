 max_dur = 180000, 600000\nmin_rating = 5  # avant calibrage\n\ndef blob\\(row\\):\n    title, album, artist, genres_str = row\\[1\\], row\\[2\\] or '', row\\[3\\] or '', row\\[4\\] or ''\n    return ' '\\.join\\(\\[title, album, artist, genres_str\\]\\)\\.lower\\(\\)\n\ndef genres_list\\(row\\):\n    return \\[g\\.strip\\(\\)\\.lower\\(\\) for g in \\(row\\[4\\] or ''\\)\\.split\\(','\\)\\]\n\nmatched = \\[\\]\nfor row in rows:\n    dur = row\\[7\\] or 0\n    if dur < min_dur or dur > max_dur:\n        continue\n    rating = row\\[5\\] or 0\n    b = blob\\(row\\)\n    gl = genres_list\\(row\\)\n    # include: genre contient keyword OU blob contient keyword\n    inc = any\\(kw in g for g in gl for kw in include_kw\\) or any\\(kw in b for kw in include_kw\\)\n    # exclude\n    exc = any\\(kw in g for g in gl for kw in exclude_kw\\) or any\\(kw in b for kw in exclude_kw\\)\n    if inc and not exc:\n        matched\\.append\\(row\\)\n\nmatched\\.sort\\(key=lambda r: \\(r\\[5\\] or 0, r\\[6\\] or 0\\), reverse=True\\)\n\nprint\\(f\"\\\\n=== Pistes matchées \\(sans seuil de note, juste keywords \\+ durée\\) : \\{len\\(matched\\)\\} ===\"\\)\nprint\\(f\"\\{'Artiste':<30\\} \\{'Titre':<40\\} \\{'Album':<35\\} \\{'Genres':<50\\} \\{'Note':>5\\} \\{'Plays':>6\\}\"\\)\nprint\\(\"-\"\\*170\\)\nfor r in matched\\[:100\\]:\n    artist = \\(r\\[3\\] or '\\?'\\)\\[:30\\]\n    title  = \\(r\\[1\\] or '\\?'\\)\\[:40\\]\n    album  = \\(r\\[2\\] or '\\?'\\)\\[:35\\]\n    genres = \\(r\\[4\\] or ''\\)\\[:50\\]\n    note   = r\\[5\\] or 0\n    plays  = r\\[6\\] or 0\n    print\\(f\"\\{artist:<30\\} \\{title:<40\\} \\{album:<35\\} \\{genres:<50\\} \\{note:>5\\} \\{plays:>6\\}\"\\)\n\n# keyword breakdown\nprint\\(\"\\\\n--- Breakdown par keyword déclencheur ---\"\\)\nfor kw in include_kw:\n    count = sum\\(1 for r in matched if kw in blob\\(r\\) or any\\(kw in g for g in genres_list\\(r\\)\\)\\)\n    print\\(f\"  \\{kw:15s\\}: \\{count\\} pistes\"\\)\nPYEOF\n$/": {
