#!/usr/bin/env bash
set -euo pipefail

if [[ -f /app/utils/songrec_rename_cli.py ]]; then
  exec python3 /app/utils/songrec_rename_cli.py "$@"
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
